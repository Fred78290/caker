#!/bin/bash

set -o pipefail

# Resolve the actual logged-in user for per-user setup in pkg postinstall context.
HOME_USER=$(stat -f %Su /dev/console 2>/dev/null)
if [ -z "${HOME_USER}" ] || [ "${HOME_USER}" = "root" ] || [ "${HOME_USER}" = "loginwindow" ]; then
	HOME_USER=$(whoami)
fi

HOME=$(dscl . -read "/Users/${HOME_USER}" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
if [ -z "${HOME}" ]; then
	HOME="${HOME:-/var/root}"
fi

# Log file for installation
HOME_UID=$(stat -f %u "${HOME}" 2>/dev/null || id -u "${HOME_USER}" 2>/dev/null || echo "$(id -u)")
LOG_FILE="${HOME}/Library/Logs/Caker/caker-postinstall.log"

mkdir -p "${HOME}/Library/Logs/Caker"

# Group all commands and tee both stdout and stderr to log file
{
	set -e

	export CAKE_HOME="${HOME}/.cake"

    echo "=== Caker Post-Installation Started at $(date) ==="
    echo "Home directory: ${HOME}"
    echo "Home UID: ${HOME_UID}"
    echo "Home user: ${HOME_USER}"

    echo "Setting up PATH..."
    echo "/Applications/Caker.app/Contents/PlugIns/caked.bundle/Contents/MacOS" > /etc/paths.d/com.aldunelabs.caker

    echo "Creating sudoers file..."
    # Create sudoers file for Caker
    cat <<EOF > /etc/sudoers.d/caked
# Caker sudoers file
%everyone ALL=(root:wheel) NOPASSWD: /Applications/Caker.app/Contents/PlugIns/caked.bundle/Contents/MacOS/caked
EOF

    echo "Setting permissions..."
    chgrp staff /etc/sudoers.d/caked
    chmod 0440 /etc/sudoers.d/caked

    echo "Generating certificates..."
    # Install the Caker service with proper UID
    sudo -u "${HOME_USER}" /Applications/Caker.app/Contents/PlugIns/caked.bundle/Contents/MacOS/caked certificates generate

    echo "Installing Caker service..."
    # Prompt for password if not provided
    if [ -z "${PASSWORD}" ]; then
        echo "Prompting user for password..."
        
        # Detect system language (check primary language preference)
        LANG_CODE=$(sudo -u "${HOME_USER}" defaults read NSGlobalDomain AppleLanguages 2>/dev/null | /usr/bin/grep -v -E '[\(\)]' | head -1 || echo "en")
        
        # Set appropriate message based on language
        if [[ "${LANG_CODE}" == *"fr"* ]]; then
            DIALOG_MESSAGE="Veuillez entrer un mot de passe pour le service Caker:"
        else
            DIALOG_MESSAGE="Please enter a password for the Caker service:"
        fi
        
        PASSWORD=$(sudo -u "${HOME_USER}" osascript -e "display dialog \"${DIALOG_MESSAGE}\" default answer \"\" with hidden answer" -e 'text returned of result' 2>/dev/null)
        if [ $? -ne 0 ] || [ -z "${PASSWORD}" ]; then
            echo "Password prompt cancelled or empty, installing without password..."
        fi
    fi
    
    # Install the Caker service with proper UID
    if [ -n "${PASSWORD}" ]; then
        sudo -S -u "${HOME_USER}" /Applications/Caker.app/Contents/PlugIns/caked.bundle/Contents/MacOS/caked set local.passphrase="${PASSWORD}" 2>/dev/null || echo "Failed to set passphrase, proceeding without it..."
    fi

    sudo -u "${HOME_USER}" /Applications/Caker.app/Contents/PlugIns/caked.bundle/Contents/MacOS/caked service install --tcp

    echo "=== Caker Post-Installation Completed at $(date) ==="
} 2>&1 | tee "${LOG_FILE}"
PIPELINE_STATUS=${PIPESTATUS[0]}

chown "${HOME_USER}:staff" "${LOG_FILE}"
exit "${PIPELINE_STATUS}"