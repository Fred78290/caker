    "mount_help" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nAdditional directory shares with an optional read-only and mount tag options (e.g. --mount=\\\"~/src/build:/opt/build\\\" or --mount=\\\"~/src/sources:/opt/sources,ro,name=Sources\\\")\"\nThe options are:\n  - ro: read-only\n  - name=name of the share\n  - uid=user id\n  - gid=group id\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nPartages de répertoires supplémentaires avec options de lecture seule et de point de montage (par exemple : `--mount=\"~/src/build:/opt/build\" ou `--mount=\"~/src/sources:/opt/sources,ro,name=Sources\"`).\nOptions :\n- ro : lecture seule\n- name : nom du partage\n- uid : identifiant utilisateur\n- gid : identifiant de groupe\n"
          }
        }
      }
    },
