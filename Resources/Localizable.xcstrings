            "state" : "translated",
            "value" : "List host network devices (physical interfaces, virtual switches, bridges) available\nto integrate with using the `--bridged` switch to the `launch` command"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liste des périphériques réseau hôtes (interfaces physiques, commutateurs virtuels, ponts)\ndisponibles pour l'intégration à l'aide de l'option `--bridged` de la commande `launch`"
          }
        }
      }
    },
