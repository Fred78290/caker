    "console_help" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n  - --console=unix — use a Unix socket for the serial console located at ~/.caked/vms/<vm-name>/console.sock\n  - --console=unix:/tmp/serial.sock — use a Unix socket for the serial console located at the specified path\n  - --console=file — use a simple file for the serial console located at ~/.caked/vms/<vm-name>/console.log\n  - --console=fd://0,1 — use file descriptors for the serial console. The first file descriptor is for reading, the second is for writing\n    ** INFO: The console doesn't work on MacOS sonoma and earlier  **\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "  \n  - --console=unix : utilise un socket Unix pour la console série situé dans ~/.caked/vms/<nom-de-la-machine-machine>/console.sock\n  - --console=unix:/tmp/serial.sock : utilise un socket Unix pour la console série situé au chemin spécifié\n  - --console=file : utilise un fichier simple pour la console série situé dans ~/.caked/vms/<nom-de-la-machine-machine>/console.log\n  - --console=fd://0,1 : utilise des descripteurs de fichiers pour la console série. Le premier descripteur est destiné à la lecture, le second à l'écriture.\n    ** INFO : La console n'est pas compatible avec macOS Sonoma et les versions antérieures. **\n"
          }
        }
      }
    },
    "Control" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contrôle"
