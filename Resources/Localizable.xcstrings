    "network_help" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nAdd a network interface to the instance, where\n<spec> is in the \\\"key=value,key=value\\\" format,\nwith the following keys available:\nname: the network to connect to (required), use\nthe networks command for a list of possible values.\n  - mode: auto|manual (default: auto)\n  - mac: hardware address (default: random).\nYou can also use a shortcut of \\\"<name>\\\" to mean \\\"name=<name>\\\".\n"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\nAjoutez une interface réseau à l'instance, où\n<spec> est au format \"clé=valeur, clé=valeur\",\navec les clés suivantes :\nnom : le réseau auquel se connecter (obligatoire). Utilisez\nla commande « networks » pour obtenir la liste des valeurs possibles.\n  - mode : auto|manual (par défaut : auto)\n  - mac : adresse MAC (par défaut : aléatoire).\nVous pouvez également utiliser le raccourci \"<nom>\" pour indiquer \"nom=<nom>\".\n"
          }
        }
      }
    },
    "network_list_abstract" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
